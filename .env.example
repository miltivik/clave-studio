# Resend. Crear nueva key. No reutilizar key vieja expuesta.
RESEND_API_KEY=

# Supabase. Requerido para guardar leads.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare Turnstile. Keys dummy oficiales para desarrollo local.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Sal privada para hash de IP. Generar valor propio en entorno real.
CONTACT_SECURITY_SALT=replace-with-random-base64

# Opcionales. Si faltan, codigo usa fallback actual.
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
CONTACT_FROM_NAME=Clave Studio
